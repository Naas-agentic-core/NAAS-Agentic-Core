{
  "version": 1,
  "consumer": "api-gateway",
  "providers": [
    "orchestrator-service",
    "research-agent"
  ],
  "http": [],
  "websocket": [
    {
      "route": "/api/chat/ws",
      "provider_default": "orchestrator-service",
      "versioning": {
        "subprotocol": "jwt",
        "query_fallback": "token",
        "api_version": "v1"
      },
      "envelope": {
        "incoming_required_fields": [
          "question"
        ],
        "outgoing_required_fields": [
          "status",
          "response"
        ]
      }
    },
    {
      "route": "/admin/api/chat/ws",
      "provider_default": "orchestrator-service",
      "versioning": {
        "subprotocol": "jwt",
        "query_fallback": "token",
        "api_version": "v1"
      },
      "envelope": {
        "incoming_required_fields": [
          "question"
        ],
        "outgoing_required_fields": [
          "status",
          "response"
        ]
      }
    }
  ]
}
