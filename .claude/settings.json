      "Write(.replit)",
      "Write(replit.nix)",
      "Write(docker-compose.yml)",
      "Write(Dockerfile)"
    ]
  },
  "model": "claude-sonnet-4-5",
  "env": {
    "PYTHONPATH": "/home/runner/workspace",
    "ENVIRONMENT": "development"
  }
