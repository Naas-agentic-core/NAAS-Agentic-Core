{
  "permissions": {
    "allow": [
      "Bash(uvicorn:*)",
      "Bash(pytest:*)",
      "Bash(ruff:*)",
      "Bash(isort:*)",
      "Bash(npm run*)",
      "Bash(python -m*)",
      "Bash(python3 -m*)",
      "Bash(python3 -c*)",
      "Bash(curl:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(echo:*)",
      "Bash(mkdir:*)",
      "Bash(chmod:*)",
      "Bash(bash scripts/*)",
      "Read(**)",
