      "Bash(pip install*)",
      "Bash(npm install*)",
      "Bash(npm uninstall*)",
      "Write(app/core/db_schema_config.py)",
      "Write(app/core/settings/base.py)",
      "Write(app/infrastructure/clients/orchestrator_client.py)",
      "Write(app/services/security/auth_persistence.py)",
